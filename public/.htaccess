# ============================================================
# Sabino Rifas — Apache / LiteSpeed Config (Hostinger)
# ============================================================

# Redirecionar todo tráfego para index.html (SPA)
Options -MultiViews
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]

# ── Desabilitar cache do LiteSpeed (Hostinger) ──
<IfModule LiteSpeed>
  CacheDisable /
</IfModule>

# ── HTML: NUNCA fica em cache (sempre fresco) ──
<FilesMatch "\.(html|htm)$">
  Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header always set Pragma "no-cache"
  Header always set Expires "Thu, 01 Jan 1970 00:00:00 GMT"
  Header always unset ETag
</FilesMatch>

# ── Imagens: revalida sempre (304 se não mudou) ──
<FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|ico|mp4|webm)$">
  Header always set Cache-Control "no-cache"
  FileETag MTime Size
</FilesMatch>

# ── CSS/JS: revalida sempre ──
<FilesMatch "\.(css|js)$">
  Header always set Cache-Control "no-cache"
</FilesMatch>

# ── Fontes: cache longo (não mudam) ──
<FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
  Header always set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# ── Compressão GZIP ──
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
  AddOutputFilterByType DEFLATE image/svg+xml application/json
</IfModule>

# ── Segurança básica ──
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
